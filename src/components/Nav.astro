---
const links = [
  { href: '#about',    label: 'Sobre mí' },
  { href: '#projects', label: 'Proyectos' },
  { href: '#value',    label: 'Valor' },
  { href: '#principles', label: 'Criterio' },
  { href: '#experience', label: 'Trayectoria' },
  { href: '#skills',   label: 'Skills' },
];

const sections = [
  { id: 'hero',       label: 'Inicio' },
  { id: 'about',      label: 'Sobre mí' },
  { id: 'projects',   label: 'Proyectos' },
  { id: 'value',      label: 'Valor' },
  { id: 'principles', label: 'Criterio' },
  { id: 'experience', label: 'Trayectoria' },
  { id: 'skills',     label: 'Skills' },
  { id: 'contact',    label: 'Contacto' },
];
---
<header class="fixed top-4 md:top-6 inset-x-0 z-30 flex justify-center px-4">
  <div class="relative w-full max-w-sm md:w-auto md:max-w-none bg-surface/80 md:bg-surface/60 backdrop-blur-xl border border-white/10 rounded-3xl md:rounded-full px-4 md:px-6 py-3 flex items-center justify-between gap-4 md:gap-12 shadow-2xl">
    <!-- Logo -->
    <a href="/" aria-label="Carlos Indriago" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-brand-600 to-accent-light flex items-center justify-center shadow-lg shadow-brand-500/20">
        <span class="font-display font-800 text-sm text-white">CI</span>
      </div>
    </a>

    <!-- Mobile current section -->
    <p
      id="mobile-current-section"
      class="pointer-events-none absolute left-1/2 -translate-x-1/2 md:hidden max-w-[10rem] truncate text-center font-mono text-[11px] font-semibold uppercase tracking-widest text-white"
      aria-live="polite"
    >
      Inicio
    </p>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-6">
      {links.map(l => (
        <a href={l.href} class="text-sm text-gray-300 hover:text-white transition-colors font-medium relative group">
          {l.label}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent-light transition-all group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center">
      <a href="#contact" class="hidden sm:inline-flex items-center gap-2 px-5 py-2 rounded-full bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium transition-colors shadow-lg shadow-brand-500/25">Hablemos</a>

      <button
        id="mobile-menu-button"
        type="button"
        class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/5 text-gray-200 hover:bg-white/10 hover:text-white transition-colors"
        aria-label="Abrir menú de navegación"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg class="menu-open h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
          <path d="M4 7h16" />
          <path d="M4 12h16" />
          <path d="M4 17h16" />
        </svg>
        <svg class="menu-close hidden h-5 w-5" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round">
          <path d="M6 6l12 12" />
          <path d="M18 6L6 18" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <nav
      id="mobile-menu"
      class="absolute left-0 right-0 top-full mt-3 hidden overflow-hidden rounded-3xl border border-white/10 bg-surface/95 p-2 shadow-2xl backdrop-blur-xl md:hidden"
      aria-label="Navegación móvil"
    >
      <div class="flex flex-col gap-1">
        {links.map(l => (
          <a href={l.href} class="mobile-menu-link rounded-2xl px-4 py-3 text-sm font-semibold text-gray-200 hover:bg-white/5 hover:text-white transition-colors">
            {l.label}
          </a>
        ))}
        <a href="#contact" class="mobile-menu-link mt-1 rounded-2xl bg-brand-600 px-4 py-3 text-center text-sm font-bold text-white shadow-lg shadow-brand-500/25 hover:bg-brand-500 transition-colors">
          Hablemos de arquitectura
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const menuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const currentSection = document.getElementById('mobile-current-section');
  const sectionLabels = new Map([
    ['hero', 'Inicio'],
    ['about', 'Sobre mí'],
    ['projects', 'Proyectos'],
    ['value', 'Valor'],
    ['principles', 'Criterio'],
    ['experience', 'Trayectoria'],
    ['skills', 'Skills'],
    ['contact', 'Contacto'],
  ]);

  if (menuButton && mobileMenu) {
    const openIcon = menuButton.querySelector('.menu-open');
    const closeIcon = menuButton.querySelector('.menu-close');

    const setMenuOpen = (isOpen) => {
      menuButton.setAttribute('aria-expanded', String(isOpen));
      menuButton.setAttribute(
        'aria-label',
        isOpen ? 'Cerrar menú de navegación' : 'Abrir menú de navegación'
      );
      mobileMenu.classList.toggle('hidden', !isOpen);
      openIcon?.classList.toggle('hidden', isOpen);
      closeIcon?.classList.toggle('hidden', !isOpen);
    };

    menuButton.addEventListener('click', () => {
      const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
      setMenuOpen(!isOpen);
    });

    mobileMenu.querySelectorAll('.mobile-menu-link').forEach((link) => {
      link.addEventListener('click', () => setMenuOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setMenuOpen(false);
    });
  }

  if (currentSection) {
    const sections = [...sectionLabels.keys()]
      .map((id) => document.getElementById(id))
      .filter(Boolean);

    let ticking = false;

    const updateCurrentSection = () => {
      const marker = window.scrollY + window.innerHeight * 0.38;
      let activeId = sections[0]?.id ?? 'hero';

      for (const section of sections) {
        if (section.offsetTop <= marker) {
          activeId = section.id;
        }
      }

      currentSection.textContent = sectionLabels.get(activeId) ?? 'Inicio';
      ticking = false;
    };

    const requestUpdate = () => {
      if (!ticking) {
        window.requestAnimationFrame(updateCurrentSection);
        ticking = true;
      }
    };

    updateCurrentSection();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);
  }
</script>

---
const links = [
  { href: '#about',    label: 'Sobre mí' },
  { href: '#projects', label: 'Proyectos' },
  { href: '#skills',   label: 'Skills' },
  { href: '#contact',  label: 'Contacto' },
];
---
<header class="fixed top-6 inset-x-0 z-50 flex justify-center px-4">
  <div class="bg-surface/60 backdrop-blur-xl border border-white/10 rounded-full px-6 py-3 flex items-center justify-between gap-8 md:gap-12 shadow-2xl">
    <!-- Logo -->
    <a href="/" aria-label="Carlos Indriago" class="flex items-center gap-2 group">
      <div class="w-8 h-8 rounded-full bg-gradient-to-tr from-brand-600 to-accent-light flex items-center justify-center shadow-lg shadow-brand-500/20">
        <span class="font-display font-800 text-sm text-white">CI</span>
      </div>
    </a>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-6">
      {links.map(l => (
        <a href={l.href} class="text-sm text-gray-300 hover:text-white transition-colors font-medium relative group">
          {l.label}
          <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-accent-light transition-all group-hover:w-full"></span>
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center">
      <a href="#contact" class="hidden sm:inline-flex items-center gap-2 px-5 py-2 rounded-full bg-brand-600 hover:bg-brand-500 text-white text-sm font-medium transition-colors shadow-lg shadow-brand-500/25">Contrátame</a>
    </div>
  </div>
</header>

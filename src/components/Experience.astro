---
import { experience } from '../data/experience';
---
<section id="experience" class="py-20 md:py-32 bg-surface relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <p class="text-accent-default font-mono text-sm font-semibold mb-3 tracking-widest uppercase">// experiencia</p>
    <h2 class="font-display font-800 text-white mb-16" style="font-size: var(--text-2xl);">
      Trayectoria
    </h2>

    <div class="space-y-0">
      {experience.map((exp, i) => (
        <div class="relative pl-10 pb-16 last:pb-0 group">
          <!-- Timeline line -->
          {i < experience.length - 1 && (
            <div class="absolute left-[13px] top-8 bottom-0 w-px bg-white/10 group-hover:bg-brand-500/30 transition-colors"></div>
          )}
          <!-- Dot -->
          <div class="absolute left-0 top-2 w-7 h-7 rounded-full bg-surface border-4 border-white/10 flex items-center justify-center group-hover:border-brand-500 transition-colors z-10">
            <div class="w-2 h-2 rounded-full bg-gray-400 group-hover:bg-brand-400 transition-colors"></div>
          </div>

          <div class="bg-background/80 backdrop-blur-sm rounded-2xl p-8 border border-white/5 hover:border-brand-500/30 transition-all hover:shadow-[0_12px_40px_rgba(37,99,235,0.05)] group-hover:-translate-y-1">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mb-4">
              <div>
                <h3 class="font-display font-800 text-white text-xl md:text-2xl mb-1 leading-tight">{exp.role}</h3>
                <p class="text-sm font-semibold text-brand-400 uppercase tracking-wider">{exp.company}</p>
              </div>
              <span class="font-mono text-sm text-gray-400 self-start md:self-auto">{exp.period}</span>
            </div>
            <div class="mb-6 space-y-4">
              <div>
                <p class="font-mono text-[11px] font-bold uppercase tracking-widest text-brand-400 mb-2">Responsabilidad</p>
                <p class="text-gray-300 leading-relaxed text-[15px]">{exp.responsibility}</p>
              </div>
              <div>
                <p class="font-mono text-[11px] font-bold uppercase tracking-widest text-brand-400 mb-2">Impacto</p>
                <ul class="space-y-2">
                  {exp.impact.map(item => (
                    <li class="flex gap-3 text-gray-300 leading-relaxed text-[15px]">
                      <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-400"></span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {exp.tags.map(tag => (
                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-brand-950/40 border border-brand-800/30 text-brand-300">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
